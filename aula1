const prompt = require("prompt-sync")()

const secreto = 42

let tentativas = 0

while (true) {
    let numero = Number(prompt("Tente adivinhar o numero: "))

    tentativas++

    if (numero === secreto) {
        console.log(`Voce acertou em ${tentativas} tentativas!`)
        break
    }

    if (numero < secreto) {
        console.log("O numero secreto e maior.")
    } else {
        console.log("O numero secreto e menor.")
    }
}









